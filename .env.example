LOG_LEVEL=INFO
OPENAI_API_KEY=
# Tarifs token : src/agentic_writer/data/openai_pricing.json
# Rafraîchir : uv run python scripts/refresh_openai_pricing.py
# openai-chat: = Chat Completions (recommandé). openai: déclenche un warning Pydantic AI.
OPENAI_MODEL=openai-chat:gpt-4.1-mini
AGENTIC_WRITER_MAX_AUDIT_RETRIES=1
# Modèles par rôle (optionnel)
# OPENAI_MODEL_ARCHITECT=openai-chat:gpt-4.1-mini
# OPENAI_MODEL_WRITER=openai-chat:gpt-4.1-mini
# OPENAI_MODEL_CHAPTER=openai-chat:gpt-4.1-mini
# OPENAI_MODEL_EDITOR=openai-chat:gpt-4.1-mini
# OPENAI_MODEL_AUDITOR=openai-chat:gpt-4.1-nano
AGENTIC_WRITER_OUTPUT=
AGENTIC_WRITER_EVAL_MODE=mock

# web/.env.local — URL API studio pour charger le manuscrit en UI
# NEXT_PUBLIC_AGENTIC_WRITER_API=http://127.0.0.1:8000
